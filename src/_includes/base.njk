<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | HausPower</title>
  <meta name="description" content="{{ description or 'HausPower offers premium electrical services for luxury homes in Kitchener-Waterloo. Expert installations and smart home technology integration.' }}">
  <link rel="canonical" href="https://hauspower.ca{{ page.url }}">
  <link rel="icon" href="/favicon.ico">

  <!-- OG tags -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }} | HausPower">
  <meta property="og:description" content="{{ description or 'HausPower offers premium electrical services for luxury homes in Kitchener-Waterloo.' }}">
  <meta property="og:image" content="https://hauspower.ca/images/og-image.jpg">
  <meta property="og:url" content="https://hauspower.ca{{ page.url }}">
  <meta name="twitter:card" content="summary_large_image">

  <!-- Fonts — Outfit only, display=swap prevents invisible text during load -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Inline font fallback: ensures Outfit applies immediately even before external CSS parses -->
  <style>body{font-family:'Outfit',sans-serif;}</style>

  <!-- CSS — ?v=2 busts Vercel's immutable cache so all browsers fetch the fixed stylesheet -->
  <link rel="stylesheet" href="/css/style.css?v=2">

  <!-- Page schema injected in body via JSON-LD -->
</head>
<body class="{{ bodyClass or '' }}">

  <!-- Header -->
  <header id="site-header" style="position:fixed;top:0;left:0;right:0;z-index:1000;transition:background 0.35s ease,box-shadow 0.35s ease,backdrop-filter 0.35s ease;background:transparent;padding:1.4rem 0;" aria-label="Site header">
    <div style="max-width:1280px;margin:0 auto;padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;">

      <!-- Logo — always light (header stays dark) -->
      <a href="/" aria-label="HausPower home">
        <img src="/images/HORIZONTAL-LIGHT-LOGO.svg" alt="HausPower" width="200" height="46" id="header-logo" style="height:40px;width:auto;display:block;">
      </a>

      <!-- Desktop nav -->
      <nav class="desktop-nav" style="display:flex;align-items:center;gap:3rem;" aria-label="Main navigation">
        <a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}">Home</a>
        <a href="/our-services/" class="nav-link {% if '/our-services' in page.url %}active{% endif %}">Services</a>
        <a href="/safety-standards/" class="nav-link {% if '/safety-standards' in page.url %}active{% endif %}">Safety</a>
        <a href="/request-a-quote/" class="btn-primary" style="padding:0.7rem 1.6rem;font-size:0.75rem;">Get a Quote</a>
      </nav>

      <!-- Hamburger -->
      <button class="hamburger-btn" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile menu overlay -->
  <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

  <!-- Mobile menu -->
  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
    <button id="mobile-close" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:#fff;font-size:1.5rem;cursor:pointer;" aria-label="Close menu">✕</button>
    <a href="/" class="nav-link" style="font-size:1.1rem;">Home</a>
    <a href="/our-services/" class="nav-link" style="font-size:1.1rem;">Our Services</a>
    <a href="/safety-standards/" class="nav-link" style="font-size:1.1rem;">Safety Standards</a>
    <a href="/request-a-quote/" class="nav-link" style="font-size:1.1rem;color:#d72327;">Get a Quote</a>
    <div style="margin-top:2rem;border-top:1px solid rgba(255,255,255,0.15);padding-top:2rem;">
      <p style="color:rgba(255,255,255,0.5);font-size:0.75rem;margin:0 0 0.5rem;">Call anytime</p>
      <a href="tel:+15196352078" style="color:#fff;font-family:'Outfit',sans-serif;font-size:1.1rem;font-weight:600;text-decoration:none;">(519) 635-2078</a>
    </div>
  </nav>

  <!-- Page content -->
  <main>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer style="background:#102026;color:rgba(255,255,255,0.65);padding:6rem 0 2.5rem;">
    <div style="max-width:1280px;margin:0 auto;padding:0 2.5rem;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:4rem;margin-bottom:5rem;">

        <!-- Brand -->
        <div>
          <img src="/images/HORIZONTAL-LOGO.svg" alt="HausPower" width="200" height="45" style="height:40px;width:auto;margin-bottom:1.5rem;">
          <p style="line-height:1.7;font-size:0.9rem;max-width:260px;">Premium electrical solutions for Ontario's finest homes. Precision, safety, and smart technology — delivered.</p>
          <div class="ecra-badge" style="margin-top:1.5rem;border-color:rgba(215,35,39,0.5);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            ECRA #7018055
          </div>
        </div>

        <!-- Pages -->
        <div>
          <p style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin:0 0 1.25rem;">Pages</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.6rem;">
            <li><a href="/">Home</a></li>
            <li><a href="/our-services/">Our Services</a></li>
            <li><a href="/safety-standards/">Safety Standards</a></li>
            <li><a href="/request-a-quote/">Request a Quote</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div>
          <p style="font-family:'Outfit',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin:0 0 1.25rem;">Contact</p>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.75rem;">
            <li>
              <a href="tel:+15196352078" style="display:flex;align-items:center;gap:0.5rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                (519) 635-2078
              </a>
            </li>
            <li>
              <a href="mailto:hello@hauspower.ca" style="display:flex;align-items:center;gap:0.5rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                hello@hauspower.ca
              </a>
            </li>
            <li style="display:flex;align-items:center;gap:0.5rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Kitchener-Waterloo, Ontario
            </li>
            <li style="margin-top:0.5rem;">
              <a href="https://instagram.com/smarthaus.ca" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:0.5rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                @smarthaus.ca
              </a>
            </li>
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div style="border-top:1px solid rgba(255,255,255,0.1);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
        <p style="margin:0;font-size:0.8rem;">© 2026 HausPower. All Rights Reserved.</p>
        <p style="margin:0;font-size:0.8rem;">Matt Allen, Master Electrician — ECRA #7018055</p>
      </div>
    </div>
  </footer>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="/js/main.js"></script>

</body>
</html>
